# Database (Turso / LibSQL)
DATABASE_URL="libsql://your-db-name-org.turso.io"
TURSO_DATABASE_URL="libsql://your-db-name-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# NextAuth
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Microsoft Azure AD OAuth
AUTH_AZURE_AD_CLIENT_ID="your-azure-client-id"
AUTH_AZURE_AD_CLIENT_SECRET="your-azure-client-secret"
AUTH_AZURE_AD_TENANT_ID="your-azure-tenant-id"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxx"

# Email (Resend)
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="noreply@korpo.in"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

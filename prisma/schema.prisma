generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Company {
  id         String   @id @default(cuid())
  name       String
  domain     String   @unique
  logo       String?
  city       String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users           User[]
  jobReferrals    JobReferral[]
  benefitProducts BenefitProduct[]
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  avatarUrl       String?
  bio             String?
  phone           String?   @unique
  city            String?
  department      String?
  jobTitle        String?
  bloodGroup          String?
  bloodDonationOptIn  Boolean   @default(false)
  reputationScore Int       @default(0)
  isVerified      Boolean   @default(false)
  isDisabled      Boolean   @default(false)
  role            String    @default("USER")
  hiddenServices  String    @default("[]")
  socialLinks     String?
  skills          String    @default("[]")
  yearsOfExp      Int?
  username        String?   @unique
  companyId       String?
  workEmail       String?   @unique
  passwordHash    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company          Company?        @relation(fields: [companyId], references: [id])
  accounts         Account[]
  sessions         Session[]
  membership       Membership?
  notifications    Notification[]
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  reviewsGiven     Review[]        @relation("ReviewsGiven")
  reviewsReceived  Review[]        @relation("ReviewsReceived")
  payments         Payment[]
  listings         Listing[]
  listingOffers       ListingOffer[]       @relation("BuyerOffers")
  listingReports      ListingReport[]
  listingEngagements  ListingEngagement[]  @relation("BuyerEngagements")
  skillListings        SkillListing[]
  skillOrdersBuying    SkillOrder[]        @relation("SkillBuyer")
  skillOrdersSelling   SkillOrder[]        @relation("SkillSeller")
  skillReviewsGiven    SkillReview[]       @relation("SkillReviewer")
  skillReviewsReceived SkillReview[]       @relation("SkillSellerReviews")
  rentalPosts      RentalPost[]
  rentalInquiries  RentalInquiry[]
  jobReferrals         JobReferral[]
  referralApplications ReferralApplication[] @relation("CandidateApplications")
  carpoolRoutes        CarpoolRoute[]
  carpoolRequests      CarpoolRequest[]      @relation("RiderRequests")
  servicePosts     ServicePost[]
  events            Event[]
  eventRsvps        EventRsvp[]
  courses           Course[]
  courseEnrollments CourseEnrollment[]
  conciergeLeads    ConciergeLead[]
  idVerificationRequests IdVerificationRequest[]
  appGrievances     AppGrievance[]
}

model Membership {
  id            String    @id @default(cuid())
  userId        String    @unique
  plan          String    @default("FREE")
  startDate     DateTime  @default(now())
  endDate       DateTime?
  razorpaySubId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("GENERAL")
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  listingId   String?
  listingType String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
}

model Review {
  id          String   @id @default(cuid())
  reviewerId  String
  revieweeId  String
  serviceType String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, revieweeId, serviceType])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  amount            Int
  type              String
  status            String   @default("PENDING")
  razorpayOrderId   String?
  razorpayPaymentId String?
  metadata          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanyRequest {
  id          String   @id @default(cuid())
  name        String
  domain      String
  city        String?
  requestedBy String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

// Alternate verification path for members whose corporate domain can't be
// confirmed via OTP/company match — proves employment with an org ID card
// instead. Login stays blocked until an admin reviews and approves it.
model IdVerificationRequest {
  id            String    @id @default(cuid())
  corpEmail     String    @unique
  phone         String
  fullName      String
  employeeId    String?
  designation   String?
  frontImageUrl String
  backImageUrl  String
  passwordHash  String?
  status        String    @default("PENDING")
  // REGISTRATION (default, pre-account) or REVERIFICATION (existing logged-in
  // user re-proving employment, e.g. after switching companies).
  requestType   String    @default("REGISTRATION")
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Service Models ───────────────────────────────────────────────────────────

model Listing {
  id             String    @id @default(cuid())
  userId         String
  title          String
  description    String
  price          Int
  category       String
  subcategory    String?
  condition      String    @default("USED")
  isNegotiable   Boolean   @default(true)
  images         String    @default("[]")
  status         String    @default("ACTIVE")
  city           String
  isBoosted      Boolean   @default(false)
  boostLevel     String    @default("NONE")
  boostExpiresAt DateTime?
  viewCount      Int       @default(0)
  // Location
  latitude       Float?
  longitude      Float?
  area           String?
  // Extra details
  brand          String?
  purchaseYear   Int?
  warranty       String?
  meetingPref    String    @default("BOTH")
  phone          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers      ListingOffer[]
  reports     ListingReport[]
  engagements ListingEngagement[]

  @@index([city, status, category])
  @@index([userId])
}

model ListingReport {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  reason    String
  details   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([status])
}

// App-wide concern/grievance — distinct from ListingReport, which is always
// tied to a specific listing. This is for general functionality issues,
// bugs, or grievances raised from the dashboard.
model AppGrievance {
  id        String    @id @default(cuid())
  userId    String
  category  String    // BUG | FEATURE_REQUEST | HARASSMENT | PAYMENT | ACCOUNT | OTHER
  message   String
  status    String    @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ListingOffer {
  id        String   @id @default(cuid())
  listingId String
  buyerId   String
  amount    Int
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([listingId, buyerId])
  @@index([listingId])
  @@index([buyerId])
}

model ListingEngagement {
  id        String    @id @default(cuid())
  listingId String
  userId    String
  type      String    @default("INTEREST") // INTEREST | VISIT
  visitDate DateTime?
  visitTime String?   // MORNING | AFTERNOON | EVENING
  message   String?
  status    String    @default("PENDING")  // PENDING | CONFIRMED | DECLINED | DONE
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation("BuyerEngagements", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
}

model RentalPost {
  id            String   @id @default(cuid())
  userId        String
  title         String
  type          String   // APARTMENT, PG, ROOM, FLATMATE, STUDIO, VILLA
  rent          Int
  deposit       Int?
  city          String
  area          String
  amenities     String    @default("[]")
  images        String    @default("[]")
  availableFrom DateTime
  status        String   @default("ACTIVE") // ACTIVE, FILLED, EXPIRED
  description   String?
  // Extra detail fields
  bhk           String?  // "1BHK", "2BHK", "3BHK", "4BHK+", "Studio", "Room", "PG Room"
  furnished     String   @default("UNFURNISHED") // UNFURNISHED, SEMI, FULLY
  floor         Int?
  totalFloors   Int?
  bathrooms     Int?     @default(1)
  gender        String   @default("ANY") // ANY, MALE, FEMALE (for PG/Flatmate)
  occupancy     String   @default("SINGLE") // SINGLE, DOUBLE, TRIPLE (for PG)
  petsAllowed   Boolean  @default(false)
  phone         String?
  viewCount     Int      @default(0)
  isBoosted     Boolean  @default(false)
  // Location
  societyName   String?
  landmark      String?
  fullAddress   String?
  latitude      Float?
  longitude     Float?
  // Property
  carpetArea    Int?
  balconies     Int      @default(0)
  propertyAge   String?  // LESS_1 / 1_5 / 5_10 / 10_PLUS
  facing        String?  // NORTH / SOUTH / EAST / WEST / NE / NW / SE / SW
  // Parking
  twoWheelerParking  String   @default("NONE")          // NONE / OPEN / COVERED
  fourWheelerParking String   @default("NONE")          // NONE / OPEN / COVERED
  visitorParking     Boolean  @default(false)
  // Utilities
  waterSupply   String   @default("24_7")               // 24_7 / SCHEDULED / TANKER / CORPORATION
  powerBackup   String   @default("NONE")               // NONE / FULL / PARTIAL / GENERATOR / INVERTER
  gasType       String   @default("NONE")               // NONE / PIPED / CYLINDER
  internet      String   @default("NOT_INCLUDED")       // NOT_INCLUDED / INCLUDED / NEGOTIABLE
  // Financials
  maintenanceAmt      Int?
  maintenanceIncluded Boolean  @default(false)
  brokerage           String   @default("NONE")         // NONE / ONE_MONTH / NEGOTIABLE
  // Rules & preferences
  workingProfOnly  Boolean  @default(false)
  studentsAllowed  Boolean  @default(true)
  couplesAllowed   Boolean  @default(false)
  familiesAllowed  Boolean  @default(true)
  smokingAllowed   Boolean  @default(false)
  alcoholAllowed   Boolean  @default(false)
  vegetarianOnly   Boolean  @default(false)
  visitorsAllowed  Boolean  @default(true)
  nonVegAllowed    Boolean  @default(true)
  // Furnishing items list
  furnishingItems  String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  inquiries RentalInquiry[]

  @@index([city, status, type])
  @@index([userId])
}

model RentalInquiry {
  id         String    @id @default(cuid())
  rentalId   String
  userId     String
  type       String    @default("INQUIRY")  // INTEREST | VISIT | INQUIRY
  message    String?
  moveInDate DateTime?
  visitDate  DateTime?
  visitTime  String?   // MORNING | AFTERNOON | EVENING
  status     String    @default("PENDING")  // PENDING | CONFIRMED | ACCEPTED | DECLINED | DONE
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  rental RentalPost @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rentalId, userId])
  @@index([rentalId])
  @@index([userId])
}

model JobReferral {
  id               String    @id @default(cuid())
  userId           String
  companyId        String
  title            String
  description      String
  department       String
  experienceMin    Int
  experienceMax    Int
  salaryMin        Int?
  salaryMax        Int?
  skills           String    @default("[]")
  jobType          String?
  workMode         String?
  location         String?
  openings         Int       @default(1)
  perks            String    @default("[]")
  interviewProcess String?
  internalCode     String?
  referralBonus    Int?
  deadline         DateTime?
  status           String    @default("OPEN")
  isBoosted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company               @relation(fields: [companyId], references: [id])
  applications ReferralApplication[]

  @@index([status, department])
}

model ReferralApplication {
  id              String   @id @default(cuid())
  referralId      String
  userId          String
  type            String   @default("INTEREST")  // INTEREST | APPLICATION
  status          String   @default("PENDING")   // PENDING | SHORTLISTED | REFERRED | HIRED | REJECTED
  coverLetter     String?
  linkedIn        String?
  resumeUrl       String?
  yearsExp        Int?
  currentCompany  String?
  currentCtc      Int?
  expectedCtc     Int?
  noticePeriod    Int?
  referrerNotes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referral JobReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  user     User        @relation("CandidateApplications", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([referralId, userId])
  @@index([referralId])
  @@index([userId])
}

model CarpoolRoute {
  id                   String   @id @default(cuid())
  userId               String
  fromLocation         String
  fromLat              Float?
  fromLng              Float?
  toLocation           String
  toLat                Float?
  toLng                Float?
  stopCoords           String?
  departureTime        String
  returnTrip           Boolean  @default(false)
  returnTime           String?
  seatsAvailable       Int
  pricePerSeat         Int
  monthlyPassAvailable Boolean  @default(false)
  monthlyPassPrice     Int?
  frequency            String
  vehicleType          String
  vehicleNumber        String?
  acAvailable          Boolean  @default(true)
  pickupPoints         String    @default("[]")
  landmarks            String?
  allowedGender        String?
  musicPolicy          String?
  luggagePolicy        String?
  notes                String?
  vehicleModel         String?
  vehicleColor         String?
  vehiclePhoto         String?
  rideStatus           String   @default("IDLE")
  liveTrackLat         Float?
  liveTrackLng         Float?
  liveTrackAt          DateTime?
  isActive             Boolean  @default(true)
  isBoosted            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests CarpoolRequest[]

  @@index([fromLocation, toLocation])
}

model CarpoolRequest {
  id           String   @id @default(cuid())
  routeId      String
  userId       String
  pickupPoint  String?
  pickupLat    Float?
  pickupLng    Float?
  dropoffPoint String?
  dropoffLat   Float?
  dropoffLng   Float?
  seatsNeeded  Int      @default(1)
  paymentMode  String?
  message      String?
  status       String   @default("PENDING")  // PENDING | APPROVED | DECLINED | CANCELLED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  route CarpoolRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  user  User         @relation("RiderRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([routeId, userId])
  @@index([routeId])
  @@index([userId])
}

model ServicePost {
  id          String   @id @default(cuid())
  userId      String
  category    String
  title       String
  description String
  priceType   String
  price       Int?
  portfolio   String    @default("[]")
  city        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category, isActive])
}

model Deal {
  id          String    @id @default(cuid())
  merchantId  String    @default("admin")
  title       String
  description String
  discount    Int
  code        String?
  validFrom   DateTime?
  validUntil  DateTime
  category    String
  images      String    @default("[]")
  isActive    Boolean   @default(true)
  // Merchant info
  merchantName    String  @default("")
  merchantUrl     String?
  companyLogo     String?
  terms           String?
  redemptionSteps String?
  website         String?
  usageLimit      Int?
  usedCount       Int     @default(0)
  viewCount       Int     @default(0)
  // Curation flags
  featured    Boolean   @default(false)
  trending    Boolean   @default(false)
  badge       String?
  // Sourcing
  source      String    @default("MANUAL")
  lastUpdated DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Affiliate
  affiliateUrl     String?
  affiliateNetwork String?  // AMAZON | FLIPKART | MYNTRA | MEESHO | etc.
  externalId       String?  // platform product/deal ID for upsert dedup
  originalPrice    Float?   // MRP / list price in INR
  salePrice        Float?   // current sale price in INR

  redemptions DealRedemption[]

  @@index([isActive, validUntil])
  @@index([featured, isActive])
  @@index([trending, isActive])
  @@index([category, isActive])
  @@index([externalId])
}

model Event {
  id              String   @id @default(cuid())
  organizerId     String
  title           String
  description     String
  category        String
  date            DateTime
  location        String
  maxParticipants Int?
  fee             Int      @default(0)
  images          String   @default("[]")
  isActive        Boolean  @default(true)
  // Enterprise fields
  agenda          String?
  onlineLink      String?
  tags            String   @default("[]")
  isBoosted       Boolean  @default(false)
  requiresApproval Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizer User        @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  rsvps     EventRsvp[]

  @@index([date, isActive, category])
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Course {
  id           String   @id @default(cuid())
  instructorId String
  title        String
  description  String
  category     String
  price        Int
  duration     String
  mode         String
  schedule     String
  images       String   @default("[]")
  isActive     Boolean  @default(true)
  // Enterprise fields
  level        String   @default("BEGINNER")    // BEGINNER | INTERMEDIATE | ADVANCED
  tags         String   @default("[]")
  prerequisites String?
  maxStudents  Int?
  curriculum   String?
  certificate  Boolean  @default(false)
  language     String   @default("English")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instructor  User               @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  enrollments CourseEnrollment[]

  @@index([isActive, category])
}

model ConciergeLead {
  id            String   @id @default(cuid())
  userId        String
  serviceType   String
  description   String
  status        String   @default("PENDING")  // PENDING | IN_REVIEW | IN_PROGRESS | COMPLETED | CANCELLED
  assignedProId String?
  notes         String?
  // Enterprise fields
  budget          Int?
  urgency         String  @default("NORMAL")  // URGENT | NORMAL | LOW
  timeline        String?
  phone           String?
  preferredContact String @default("EMAIL")   // EMAIL | PHONE | WHATSAPP
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, serviceType])
  @@index([userId])
}

// ─── Skill Marketplace ───────────────────────────────────────────────────────

model SkillListing {
  id           String   @id @default(cuid())
  userId       String

  // Core
  title        String
  tagline      String?
  category     String   // TECH | DESIGN | BUSINESS | LANGUAGE | LEGAL | FINANCE | WELLNESS | COACHING | CREATIVE | ENGINEERING | DATA | MARKETING
  subcategory  String?
  skills       String   @default("[]")
  description  String
  deliverables String   @default("[]")
  requirements String?
  faqs         String?

  // Pricing
  pricingModel String   @default("PACKAGE") // PACKAGE | HOURLY | FIXED
  hourlyRate   Int?
  packages     String?

  // Format & availability
  format       String   @default("ONLINE")  // ONLINE | IN_PERSON | BOTH
  location     String?
  timezone     String?  @default("Asia/Kolkata")
  availability String?
  maxClientsPerMonth Int?

  // Credentials
  yearsExp        Int?
  certifications  String   @default("[]")
  portfolioUrl    String?
  linkedIn        String?

  // Denormalised stats
  totalOrders     Int    @default(0)
  completedOrders Int    @default(0)
  avgRating       Float?
  reviewCount     Int    @default(0)
  responseTimeMins Int?

  // Status
  status      String   @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED | UNDER_REVIEW
  isFeatured  Boolean  @default(false)
  isVerified  Boolean  @default(false)
  viewCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders  SkillOrder[]
  reviews SkillReview[]

  @@index([category, status])
  @@index([userId])
}

model SkillOrder {
  id          String   @id @default(cuid())
  listingId   String
  buyerId     String
  sellerId    String

  // Package chosen
  packageName String?
  packageIdx  Int?
  agreedPrice Int
  currency    String   @default("INR")

  // Lifecycle:  INQUIRY → NEGOTIATING → CONFIRMED → IN_PROGRESS → DELIVERED → COMPLETED
  //                     ↘ DECLINED        ↘ CANCELLED                 ↘ DISPUTED → RESOLVED
  status      String   @default("INQUIRY")

  // Buyer requirements
  requirements String?
  attachments  String    @default("[]")
  buyerNote    String?

  // Negotiation
  counterPrice Int?

  // Scheduling (post-confirm)
  sessionDate  DateTime?
  sessionTime  String?
  meetLink     String?

  // Payment
  paymentMode   String?   // UPI | TRANSFER | CASH | WALLET
  paymentStatus String    @default("PENDING") // PENDING | PAID | REFUNDED
  invoiceId     String?

  // Delivery
  deliveryNote  String?
  deliverables  String    @default("[]")
  deliveredAt   DateTime?

  // Completion / cancellation
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  // Dispute
  disputeReason   String?
  disputeNote     String?
  disputeOpenedAt DateTime?
  resolvedAt      DateTime?
  resolutionNote  String?

  // Seller private notes
  sellerNote   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing SkillListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User         @relation("SkillBuyer",  fields: [buyerId],  references: [id])
  seller  User         @relation("SkillSeller", fields: [sellerId], references: [id])
  review  SkillReview?

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model SkillReview {
  id         String   @id @default(cuid())
  listingId  String
  orderId    String   @unique
  reviewerId String
  sellerId   String

  rating          Int      // 1–5 overall
  ratingQuality   Int?     // 1–5 quality
  ratingComm      Int?     // 1–5 communication
  ratingPunctual  Int?     // 1–5 on-time delivery
  headline        String?
  body            String?
  wouldRepeat     Boolean  @default(true)
  isAnonymous     Boolean  @default(false)

  sellerReply String?
  repliedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing  SkillListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  order    SkillOrder   @relation(fields: [orderId],   references: [id], onDelete: Cascade)
  reviewer User         @relation("SkillReviewer",      fields: [reviewerId], references: [id])
  seller   User         @relation("SkillSellerReviews", fields: [sellerId],   references: [id])

  @@index([listingId])
  @@index([sellerId])
}

model BenefitProduct {
  id          String   @id @default(cuid())
  providerId  String
  type        String
  title       String
  description String
  minAmount   Int?
  maxAmount   Int?
  contactUrl  String
  isActive    Boolean  @default(true)
  // Enterprise fields
  features         String   @default("[]")
  eligibility      String?
  interestRate     String?
  tenure           String?
  applicationSteps String   @default("[]")
  processingTime   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider Company @relation(fields: [providerId], references: [id])

  @@index([type, isActive])
}

model CourseEnrollment {
  id          String   @id @default(cuid())
  courseId    String
  userId      String
  status      String   @default("ENROLLED")  // ENROLLED | COMPLETED | DROPPED
  enrolledAt  DateTime @default(now())
  completedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model DealRedemption {
  id         String   @id @default(cuid())
  dealId     String
  userId     String
  redeemedAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
  @@index([dealId])
  @@index([userId])
}
